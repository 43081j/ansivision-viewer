{
  "name": "@ansivision/viewer",
  "version": "0.0.0-dev",
  "description": "A viewer for replaying terminal sessions recorded with ansivision.",
  "main": "./lib/main.js",
  "type": "module",
  "bin": {
    "ansivision-viewer": "lib/bin.js"
  },
  "exports": {
    ".": {
      "types": "./lib/main.d.ts",
      "default": "./lib/main.js"
    }
  },
  "files": [
    "lib",
    "!lib/**/*.test.js",
    "!lib/**/*.test.d.ts"
  ],
  "scripts": {
    "build:clean": "node -e \"require('fs').rmSync('./lib', { recursive: true, force: true })\"",
    "build": "npm run build:clean && tsgo",
    "lint:js": "oxlint src",
    "lint:format": "oxfmt --check src",
    "lint": "npm run lint:js && npm run lint:format",
    "format": "oxfmt --write src",
    "test": "vitest run"
  },
  "keywords": [
    "ansi",
    "term",
    "terminal",
    "ink"
  ],
  "author": "James Garbutt (https://github.com/43081j)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/43081j/ansivision-viewer#readme",
  "bugs": {
    "url": "https://github.com/43081j/ansivision-viewer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/43081j/ansivision-viewer.git"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@typescript/native-preview": "^7.0.0-dev.20260509.2",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "ansivision": "^0.2.7"
  }
}
